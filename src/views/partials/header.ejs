<!-- =========================== HEADER ========================= -->
<header class="site-header">
    <div class="header-container">

        <!-- Icône user (mobile uniquement) -->
        <% if (user) { %>

            <a href="/api/auth/logout" class="mobile-user">Déconnexion</a>

        <% } else { %>

        <button class="mobile-user">👤</button>

        <% } %>

        <!-- Logo -->
        <a href="/home" class="logo">
            <img src="/assets/logo/logo.svg" alt="Logo Lectio">
        </a>

        <!-- Recherche -->
        <div class="search-container">

            <form class="search-bar">

                <input id="searchInput" type="text" placeholder="Rechercher un livre ou un auteur">

            </form>

            <!-- Popup -->
            <div id="searchPopup" class="popup">

                <div id="resultLivres">
                    <h3>Livres</h3>
                </div>

                <div id="resultAuteurs">
                    <h3>Auteurs</h3>
                </div>

            </div>

        </div>

        <!-- Zone utilisateur -->
        <div class="user-area">

            <div class="header-actions">

                <% if (user) { %>

                <div class="user-menu">

                    <button class="user-button">

                        <span class="welcome-text">Bienvenue, <%= user.name.split(" ")[0] %></span>

                        <span class="user-arrow">▼</span>

                    </button>

                    <div class="user-dropdown">

                        <a href="/library">Ma bibliothèque (<%= libraryCount %>)</a>

                        <a href="/api/auth/logout">Déconnexion</a>

                    </div>

                </div>

                <% } else { %>

                    <button class="login-btn">Connexion</button>

                <% } %>

                <button id="mobileSearchBtn" class="mobile-search">🔍</button>

                <button class="accessibility-toggle" aria-label="Mode accessibilité"><img src="/assets/icons/handicap.svg"></button>

            </div>

        </div>

    </div>
</header>