<main class="page page-genre-selected">

    <!-- BANNER -->

    <section class="genre-banner">

        <img 
            src="/assets/banner/<%= genreSlug %>.png" 
            alt="<%= genreName %>"
        >

    </section>

    <%- include("../partials/breadcrumb") %>


    <!-- BOOKS -->

    <section class="genre-books">

        <div class="container">

            <div class="books-grid">

                <% books.forEach(book => { %>

                    <article class="book-card">

                        <a href="/books/<%= book.id %>" class="book-link">

                            <div class="book-cover">

                                <img src="<%= book.volumeInfo.imageLinks?.thumbnail || '/assets/img/default-book.png' %>" alt="<%= book.volumeInfo.title %>">

                            </div>

                            <h3 class="book-title"><%= book.volumeInfo.title %></h3>

                            <p class="book-author"><%= book.volumeInfo.authors?.[0] || "Auteur inconnu" %></p>

                        </a>

                    </article>

                <% }) %>

            </div>

        </div>

    </section>

</main>

<div id="loginContainer"></div>